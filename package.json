{
  "name": "tcat-archiver",
  "version": "2.0.0",
  "type": "module",
  "description": "archive anyone's tweets and media into a self-contained html viewer, powered by emusks",
  "bin": {
    "tcat-archive": "src/cli.js"
  },
  "scripts": {
    "start": "bun run src/cli.js",
    "lint": "biome check src",
    "format": "biome format --write src"
  },
  "keywords": ["twitter", "x", "archive", "emusks"],
  "author": {
    "name": "tiago",
    "email": "hi@tiago.zip"
  },
  "license": "AGPL-3.0",
  "dependencies": {
    "emusks": "^2.1.2",
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4"
  }
}
